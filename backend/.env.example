APP_NAME=local-recruiter-outreach
DATABASE_URL=sqlite:///./local_recruiter_outreach.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.2
SEMANTIC_MODEL=sentence-transformers/all-MiniLM-L6-v2
DISCOVERY_MODE=live
DISCOVERY_MAX_CONTACTS=5
DISCOVERY_MAX_RESULTS_PER_QUERY=5
DISCOVERY_REQUEST_DELAY_MS=700
DISCOVERY_USE_PLAYWRIGHT_FALLBACK=false
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=
SMTP_USE_TLS=true

